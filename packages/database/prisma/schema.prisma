generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String      @id @default(uuid())
  email       String      @unique
  username    String
  avatar      String?
  password    String?
  accountType AccountType @default(DEFAULT)
  userRole    UserRole    @default(USER)

  isVerified   Boolean   @default(false)
  otp          String?
  otpValidTime DateTime?

  creditBalance Int            @default(0)
  paymentOrders PaymentOrder[]
  creditLedger  CreditLedger[]

  forms Form[]

  createdAt DateTime @default(now())
}

model CreditPackage {
  id           String  @id @default(uuid())
  name         String
  credits      Int
  priceInPaise Int
  isActive     Boolean @default(true)

  paymentOrders PaymentOrder[]

  createdAt DateTime @default(now())
}

model PaymentOrder {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(references: [id], fields: [userId])
  creditPackageId String
  creditPackage   CreditPackage @relation(references: [id], fields: [creditPackageId])

  razorpayOrderId   String? @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?

  amountInPaise  Int
  creditsToGrant Int
  status         PaymentStatus @default(CREATED)

  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CreditLedger {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(references: [id], fields: [userId])

  type CreditTransactionType

  amount          Int
  previousBalance Int
  currentBalance  Int
  referenceId     String @unique

  createdAt DateTime @default(now())
}

model Form {
  id          String  @id @default(uuid())
  slug        String  @unique
  title       String
  description String
  coverImage  String?
  authorId    String
  author      User    @relation(fields: [authorId], references: [id])

  isPublished   Boolean @default(false)
  publishedLink String?
  responseLimit Int?

  formFields         FormField[]
  submissions        Submission[]
  responseEmbeddings ResponseEmbedding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model FormField {
  id        String        @id @default(uuid())
  label     String
  type      FormFieldType
  required  Boolean       @default(false)
  wordLimit Int?
  order     Int
  options   String[]

  formId String
  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)

  fieldAnswers FieldAnswer[]

  createdAt DateTime @default(now())
}

model FieldAnswer {
  id           String     @id @default(uuid())
  value        Json
  formFieldId  String
  formField    FormField  @relation(fields: [formFieldId], references: [id], onDelete: Cascade)
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model Submission {
  id           String        @id @default(uuid())
  ipAddress    String?
  userAgent    String?
  fieldAnswers FieldAnswer[]
  formId       String
  form         Form          @relation(fields: [formId], references: [id], onDelete: Cascade)

  responseEmbedding ResponseEmbedding?

  createdAt DateTime @default(now())
}

model ResponseEmbedding {
  id           String     @id @default(uuid())
  formId       String
  form         Form       @relation(references: [id], fields: [formId], onDelete: Cascade)
  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  document  String?                @db.Text
  embedding Unsupported("vector")?
  // embedding Unsupported("vector(3072)")?
  status    EmbeddingStatus        @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([formId])
}

enum AccountType {
  DEFAULT
  GOOGLE
}

enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
}

enum CreditTransactionType {
  PURCHASE
  RESERVE
  USAGE
  REFUND
}

enum FormFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  EMAIL
  DROPDOWN
  // DATE
  // CHECKBOX
  // RADIO
}

enum EmbeddingStatus {
  PENDING
  COMPLETED
  FAILED
}
